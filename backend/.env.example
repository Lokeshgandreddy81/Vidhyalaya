# MongoDB Atlas Connection String
# Get this from MongoDB Atlas: Connect -> Drivers -> Copy Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/vidyal-ai?retryWrites=true&w=majority

# Server Configuration
PORT=5001
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# CORS - Frontend URL
FRONTEND_URL=http://localhost:3000

# LlamaCloud API Key for LlamaParse
LLAMAPARSE_API_KEY=your_llamacloud_api_key_here
